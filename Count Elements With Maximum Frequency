class Solution {
    public int maxFrequencyElements(int[] nums) {
        Map<Integer, Integer> map = new HashMap<>();
        int max = 0;

        for (int num : nums) {
            int freq = map.getOrDefault(num, 0) + 1;
            map.put(num, freq);
            max = Math.max(max, freq);
        }

        int count = 0;

        for (int val : map.values()) {
            if (val == max) count += val;
        }

        return count;
    }
}
